{
  "manifest_version": 3,
  "name": "Open Cowork - Progress Tracker",
  "version": "1.0.0",
  "description": "Automatic progress tracker for career development. Tracks your browser-based work activities, categorizes learning and productivity, and syncs with Coeadapt.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "alarms",
    "idle"
  ],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
